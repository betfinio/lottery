{
	"name": "@betfinio/lottery",
	"private": true,
	"version": "1.0.0",
	"scripts": {
		"build": "rsbuild build",
		"check": "biome check --write",
		"dev": "bun run build:schema:dev && rsbuild dev --open",
		"prod": "bun run build:schema:prod && rsbuild dev --env-mode production --open",
		"format": "biome format --write",
		"secret:dev": "bun run secret.ts -- development dev",
		"secret:prod": "bun run secret.ts -- production prod/io",
		"build:schema:local": "dotenv -e .env.localhost.local -- graphclient build",
		"build:schema:dev": "dotenv -e .env.development.local -- graphclient build",
		"build:schema:prod": "dotenv -e .env.production.local -- graphclient build"
	},
	"dependencies": {
		"@betfinio/abi": "^2.3.0",
		"@betfinio/components": "^1.3.6-dev.1",
		"@module-federation/enhanced": "^0.7.7",
		"@module-federation/rsbuild-plugin": "^0.8.1",
		"@tanstack/react-query": "^5.62.2",
		"@tanstack/react-router": "^1.85.5",
		"@tanstack/react-table": "^8.20.5",
		"consola": "^3.2.3",
		"framer-motion": "^11.13.1",
		"graphql": "^16.9.0",
		"i18next": "^24.0.5",
		"i18next-browser-languagedetector": "^8.0.0",
		"i18next-icu": "^2.3.0",
		"intl-messageformat": "^10.7.10",
		"lucide-react": "^0.417.0",
		"luxon": "^3.5.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^15.1.3",
		"tailwind-merge": "^2.5.5",
		"tailwindcss": "^3.4.16",
		"tailwindcss-animate": "^1.0.7",
		"wagmi": "^2.13.3"
	},
	"devDependencies": {
		"@aws-sdk/client-secrets-manager": "^3.699.0",
		"@biomejs/biome": "^1.9.4",
		"@commitlint/cli": "^19.6.0",
		"@commitlint/config-conventional": "^19.6.0",
		"@graphprotocol/client-cli": "^3.0.7",
		"@rsbuild/core": "^1.1.8",
		"@rsbuild/plugin-react": "^1.0.7",
		"@rsbuild/plugin-svgr": "^1.0.6",
		"@tanstack/router-plugin": "^1.85.3",
		"@types/bun": "^1.1.14",
		"@types/luxon": "^3.4.2",
		"@types/react": "^18.3.13",
		"@types/react-dom": "^18.3.1",
		"add": "^2.0.6",
		"dotenv-cli": "^7.4.4",
