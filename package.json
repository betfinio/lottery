{
	"name": "@betfinio/lottery",
	"private": true,
	"version": "1.0.0",
	"scripts": {
		"prebuild": "graphclient build",
		"build": "rsbuild build",
		"check": "biome check --write",
		"dev": "bun run build:schema:dev && rsbuild dev --open",
		"prod": "bun run build:schema:prod && rsbuild dev --env-mode production --open",
		"format": "biome format --write",
		"secret:dev": "bun run secret.ts -- development dev",
		"secret:prod": "bun run secret.ts -- production prod/io",
		"build:schema:dev": "dotenv -e .env.development.local -- graphclient build",
		"build:schema:prod": "dotenv -e .env.production.local -- graphclient build"
	},
	"dependencies": {
		"@betfinio/abi": "^2.3.3",
		"@betfinio/components": "^1.5.5",
		"@module-federation/enhanced": "^0.8.9",
		"@tanstack/react-query": "^5.64.2",
		"@tanstack/react-router": "^1.97.3",
		"@tanstack/react-table": "^8.20.6",
		"consola": "^3.4.0",
		"framer-motion": "^11.18.2",
		"i18next": "^24.2.1",
		"i18next-browser-languagedetector": "^8.0.2",
		"i18next-icu": "^2.3.0",
		"intl-messageformat": "^10.7.14",
		"lucide-react": "^0.468.0",
		"luxon": "^3.5.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-i18next": "^15.4.0",
		"tailwind-merge": "^2.6.0",
		"tailwindcss": "^3.4.17",
		"tailwindcss-animate": "^1.0.7",
		"wagmi": "^2.14.8"
	},
	"devDependencies": {
		"@aws-sdk/client-secrets-manager": "^3.731.1",
		"@biomejs/biome": "^1.9.4",
		"@commitlint/cli": "^19.6.1",
		"@commitlint/config-conventional": "^19.6.0",
		"@graphprotocol/client-cli": "^3.0.7",
		"@module-federation/rsbuild-plugin": "^0.8.9",
		"@rsbuild/core": "^1.1.14",
		"@rsbuild/plugin-react": "^1.1.0",
		"@rsbuild/plugin-svgr": "^1.0.6",
		"@tanstack/router-plugin": "^1.97.3",
		"@types/bun": "^1.1.18",
		"@types/luxon": "^3.4.2",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"add": "^2.0.6",
