		"@tanstack/react-query": "5.66.10",
		"@tanstack/react-router": "^1.124.0",
		"@tanstack/react-table": "^8.21.3",
		"canvas-confetti": "^1.9.3",
		"consola": "^3.4.2",
		"framer-motion": "^12.23.0",
		"i18next": "^25.3.0",
		"i18next-browser-languagedetector": "^8.2.0",
		"i18next-icu": "^2.3.0",
		"intl-messageformat": "^10.7.16",
