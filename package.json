{
	"name": "@betfinio/lottery",
	"private": true,
	"version": "1.0.0",
	"scripts": {
		"prebuild": "graphclient build",
		"build": "rsbuild build",
		"check": "biome check --write",
		"start": "bun run scripts/server.ts",
		"dev": "bun run build:schema:dev && rsbuild dev --open",
		"prod": "bun run build:schema:prod && rsbuild dev --env-mode production --open",
		"format": "biome format --write",
		"build:schema:dev": "dotenv -e .env.development.local -- graphclient build",
		"build:schema:prod": "dotenv -e .env.production.local -- graphclient build",
		"secret:dev": "./scripts/fetch-secrets.sh  development dev",
		"secret:prod": "./scripts/fetch-secrets.sh  production prod-bet",
		"secret:cleanup": "./scripts/cleanup-1password.sh"
	},
	"dependencies": {
		"@betfinio/abi": "2.9.1",
		"@betfinio/components": "2.7.1",
		"@privy-io/react-auth": "2.24.0",
		"@tanstack/react-query": "5.66.10",
		"@tanstack/react-router": "1.131.37",
		"@tanstack/react-table": "8.21.3",
		"canvas-confetti": "1.9.4",
		"consola": "3.4.2",
		"hono": "4.11.7",
		"i18next": "25.5.2",
		"i18next-browser-languagedetector": "8.2.0",
		"i18next-icu": "2.4.0",
		"intl-messageformat": "10.7.18",
		"lucide-react": "0.553.0",
		"luxon": "3.7.2",
		"motion": "12.23.24",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-i18next": "15.7.3",
		"tailwindcss": "4.1.17",
		"tw-animate-css": "1.4.0",
		"viem": "2.33.3",
		"wagmi": "2.16.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.4",
		"@commitlint/cli": "20.1.0",
		"@commitlint/config-conventional": "20.0.0",
		"@graphprotocol/client-cli": "3.0.7",
		"@module-federation/enhanced": "0.19.1",
		"@module-federation/rsbuild-plugin": "0.19.1",
		"@rsbuild/core": "1.6.3",
		"@rsbuild/plugin-react": "1.4.2",
		"@rsbuild/plugin-svgr": "1.2.2",
		"@tailwindcss/postcss": "4.1.17",
		"@tanstack/router-plugin": "1.135.0",
		"@types/bun": "1.3.2",
		"@types/canvas-confetti": "1.9.0",
		"@types/luxon": "3.7.1",
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"dotenv-cli": "11.0.0",
		"lefthook": "2.0.3",
		"typescript": "5.9.3"
	}
}
